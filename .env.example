DATABASE_URL="file:./prisma/dev.db"
SESSION_SECRET="generate-a-long-random-string"
OTP_MOCK="true"
NEXT_PUBLIC_OTP_MOCK="true"
NEXT_PUBLIC_OTP_DOMAIN="reimburse-jade.vercel.app"

# Live OTP (OTP_MOCK=false) — WhatsApp Cloud API + template reimburse_login_otp
# WHATSAPP_ACCESS_TOKEN=""          # System user token (not temporary)
# WHATSAPP_PHONE_NUMBER_ID=""       # Yellow Metal +91 — API Setup when selected
# WHATSAPP_OTP_TEMPLATE_NAME="reimburse_login_otp"
# WHATSAPP_OTP_TEMPLATE_LANGUAGE="en"
# WHATSAPP_OTP_TEMPLATE_HAS_BUTTON="true"
# WHATSAPP_API_VERSION="v25.0"
# Or MSG91 (India SMS + DLT)
# MSG91_AUTH_KEY=""
# MSG91_TEMPLATE_ID=""
# Or Twilio SMS
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# RazorpayX payouts — keep MOCK until OTP is live; then add live keys
RAZORPAYX_MOCK="true"
RAZORPAYX_KEY_ID=""
RAZORPAYX_KEY_SECRET=""
RAZORPAYX_ACCOUNT_NUMBER=""
RAZORPAYX_PAYOUT_MODE="IMPS"
RAZORPAYX_WEBHOOK_SECRET=""
