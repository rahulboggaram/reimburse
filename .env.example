# Local SQLite, or Postgres. On Vercel + Supabase use the *pooler* URL (port 6543) for DATABASE_URL.
DATABASE_URL="file:./prisma/dev.db"
# DIRECT_URL="postgresql://..."  # Supabase direct (5432) — for prisma migrate only

# Receipt photos in Supabase Storage (recommended on Vercel).
# Project Settings → API → Project URL and service_role key (never expose service_role to the browser).
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."  # or SUPABASE_SECRET_KEY
# After setting env vars, run scripts/supabase-receipts-bucket.sql in the SQL Editor once.

SESSION_SECRET="generate-a-long-random-string"
OTP_MOCK="true"
NEXT_PUBLIC_OTP_MOCK="true"
NEXT_PUBLIC_OTP_DOMAIN="reimburse-jade.vercel.app"

# Live OTP (OTP_MOCK=false) — Email via Postmark
# POSTMARK_SERVER_TOKEN=""          # postmarkapp.com → Servers → API tokens
# OTP_EMAIL_FROM="Reimburse <otp@reimburse.yellowmetal.co>"   # Must use a verified domain in Postmark

# RazorpayX payouts
RAZORPAYX_KEY_ID=""
RAZORPAYX_KEY_SECRET=""
RAZORPAYX_ACCOUNT_NUMBER=""
RAZORPAYX_PAYOUT_MODE="IMPS"
RAZORPAYX_WEBHOOK_SECRET=""
# Live payouts from Vercel need a VPS with a static IP (see relay/SETUP.md):
# RAZORPAYX_RELAY_URL="http://YOUR_VPS_IP:8787"
# RAZORPAYX_RELAY_SECRET="long-random-string-same-on-vps"
