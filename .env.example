# Local SQLite, or Postgres. On Vercel + Supabase use the *pooler* URL (port 6543) for DATABASE_URL.
DATABASE_URL="file:./prisma/dev.db"
# DIRECT_URL="postgresql://..."  # Supabase direct (5432) — for prisma migrate only
SESSION_SECRET="generate-a-long-random-string"
OTP_MOCK="true"
NEXT_PUBLIC_OTP_MOCK="true"
NEXT_PUBLIC_OTP_DOMAIN="reimburse-jade.vercel.app"

# Live OTP (OTP_MOCK=false) — Option A: Email via Resend (simplest — recommended)
# RESEND_API_KEY=""                 # resend.com → API Keys
# OTP_EMAIL_FROM="Reimburse <otp@yourdomain.com>"   # Must use a verified domain in Resend

# Live OTP (OTP_MOCK=false) — Option B: AiSensy (easier — they handle Meta for you)
# AISENSY_API_KEY=""                 # app.aisensy.com → Manage → API Key
# AISENSY_CAMPAIGN_NAME=""           # Live API campaign name (Authentication template)
# AISENSY_TEMPLATE_PARAM_COUNT="1"   # Use "2" if AiSensy test cURL needs OTP in body + button
# AISENSY_USER_NAME="User"           # Optional display name in AiSensy payload

# Live OTP (OTP_MOCK=false) — Option C: Meta WhatsApp Cloud API direct
# WHATSAPP_ACCESS_TOKEN=""          # System user token (not temporary)
# WHATSAPP_PHONE_NUMBER_ID=""       # Yellow Metal +91 — API Setup when selected
# WHATSAPP_OTP_TEMPLATE_NAME="reimburse_login_otp"
# WHATSAPP_OTP_TEMPLATE_LANGUAGE="en"
# WHATSAPP_OTP_TEMPLATE_HAS_BUTTON="true"
# WHATSAPP_API_VERSION="v25.0"
# WHATSAPP_TWO_STEP_PIN="123456"       # Only for npm run whatsapp:register (6-digit business PIN)
# Or MSG91 (India SMS + DLT)
# MSG91_AUTH_KEY=""
# MSG91_TEMPLATE_ID=""
# Or Twilio SMS
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# RazorpayX payouts — use VPS relay on Vercel (see relay/SETUP.md) or direct keys locally
RAZORPAYX_KEY_ID=""
RAZORPAYX_KEY_SECRET=""
RAZORPAYX_ACCOUNT_NUMBER=""
RAZORPAYX_PAYOUT_MODE="IMPS"
RAZORPAYX_WEBHOOK_SECRET=""
# Live payouts from Vercel need a VPS with a static IP (see relay/SETUP.md):
# RAZORPAYX_RELAY_URL="http://YOUR_VPS_IP:8787"
# RAZORPAYX_RELAY_SECRET="long-random-string-same-on-vps"
